{
  "name": "@opencode/server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "lint": "eslint . --ext .ts --cache --cache-strategy content --cache-location .eslintcache",
    "test": "node --import tsx --test --test-concurrency=1 src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.7.6",
    "@opencode/agent": "workspace:*",
    "@opencode/orm": "workspace:*",
    "@opencode/shared": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.7.2",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
