{
  "name": "opencode-web-lite-mvp",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "pnpm -r build",
    "db:apply": "pnpm --filter @opencode/db apply",
    "db:lint": "pnpm --filter @opencode/db lint",
    "db:status": "pnpm --filter @opencode/db status",
    "db:sync": "pnpm --filter @opencode/orm introspect",
    "dev:server": "pnpm --filter @opencode/server dev",
    "dev:web": "pnpm --filter @opencode/web dev",
    "format": "prettier --write --log-level warn \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.1"
  }
}
